  "private": true,
  "description": "SweetEscape — an immersive bakery in Chandigarh, built with Next.js 15, React Three Fiber, GSAP, and a hand-tuned Cafe x Artistic design system.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"const n=require('net'),s=n.createServer();s.once('error',()=>{console.error('\\x1b[31mPort 3000 in use — stop the dev server before building\\x1b[0m');process.exit(1)});s.listen(3000,()=>s.close())\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/caveat": "^5.2.8",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
