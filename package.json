    "@phosphor-icons/react": "^2.1.7",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lenis": "^1.1.20",
    "motion": "^12.0.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "three": "^0.171.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
